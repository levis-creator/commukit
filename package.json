{
  "name": "commukit",
  "version": "0.0.0",
  "description": "Reusable multi-tenant communications microservice — chat, audio, video, and SIP room provisioning via pluggable Matrix, Janus, LiveKit, and Kamailio adapters.",
  "private": true,
  "license": "Apache-2.0",
  "author": "Levis Nyingi <levis.nyingi@gmail.com>",
  "homepage": "https://github.com/levis-creator/commukit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/levis-creator/commukit.git"
  },
  "bugs": {
    "url": "https://github.com/levis-creator/commukit/issues"
  },
  "keywords": [
    "communications",
    "microservice",
    "nestjs",
    "matrix",
    "janus",
    "livekit",
    "kamailio",
    "sip",
    "webrtc",
    "chat"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nest build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.16",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.7",
    "@prisma/client": "^7.7.0",
    "amqp-connection-manager": "^4.1.15",
    "amqplib": "^0.10.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^16.6.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/amqplib": "^0.10.8",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.10.7",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "prisma": "^5.20.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "coverageThreshold": {
      "global": {
        "statements": 45,
        "branches": 40,
        "functions": 40,
        "lines": 47
      }
    },
    "testEnvironment": "node"
  }
}
