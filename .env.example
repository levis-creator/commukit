# ─────────────────────────────────────────────────────────────────────────────
# Communications Service — Configuration Template
# Copy to .env and adjust values for your environment.
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
COMMS_SERVICE_PORT=3014

# ─────────────────────────────────────────────────────────────────────────────
# Capability enable flags
#
# Each capability can be turned off independently so consumers running
# chat-only, audio-only, or any other partial deployment pay zero cost for
# the pieces they don't use. Defaults preserve today's behaviour (chat +
# audio/video on, SIP off).
#
# Turning a capability OFF means:
#   - The corresponding NestJS module is not imported into AppModule
#   - The service class is never instantiated (zero memory / CPU)
#   - /health reports the capability as "disabled"
#   - Session responses surface `{ status: 'unavailable', reason: '<X> disabled' }`
#
# Pair these flags with COMPOSE_PROFILES below to also skip the sidecar
# containers (Synapse, Janus, coturn, Kamailio) that provide each capability.
# ─────────────────────────────────────────────────────────────────────────────
MATRIX_ENABLED=true
JANUS_ENABLED=true
SIP_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────
# Provider selection (Phase 1 of the pluggable provider abstraction)
#
# The communications-service exposes its media (audio/video) and chat
# transports behind two interfaces: `MediaProvider` and `ChatProvider`
# (see src/providers/). The values below pick which concrete implementation
# the DI container wires up at boot.
#
# Defaults match today's behaviour. Changing MEDIA_PROVIDER to `livekit`
# will NOT take effect until the LiveKit adapter ships — the env var is
# surfaced early so infrastructure (docker-compose profile, LIVEKIT_*
# secrets) can land first.
# ─────────────────────────────────────────────────────────────────────────────
MEDIA_PROVIDER=janus
CHAT_PROVIDER=matrix

# ─────────────────────────────────────────────────────────────────────────────
# Docker Compose profiles
#
# Profiles gate optional containers so `docker compose up` only starts the
# infrastructure the deployment actually needs:
#
#   chat    → Matrix Synapse
#   media   → Janus Gateway + coturn (current default audio/video backend)
#   sip     → Kamailio SIP registrar (also requires media)
#   livekit → LiveKit server (alternative to `media`; adapter TBD)
#
# `media` and `livekit` are mutually-exclusive — pick one. Running both
# costs RAM and adds no value.
#
# Examples:
#   COMPOSE_PROFILES=chat              # chat only (no audio/video)
#   COMPOSE_PROFILES=media             # audio/video via Janus
#   COMPOSE_PROFILES=chat,media        # default (chat + Janus)
#   COMPOSE_PROFILES=chat,media,sip    # everything including SIP softphones
#   COMPOSE_PROFILES=chat,livekit      # chat + LiveKit (future)
#
# The recommended default below matches today's behaviour. Override per
# environment as needed.
# ─────────────────────────────────────────────────────────────────────────────
COMPOSE_PROFILES=chat,media

# Database
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/vps-comms-db?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin123@localhost:5672
RMQ_EXCHANGE=comms_events_fanout
RMQ_QUEUE=comms_events

# Internal Service-to-Service Auth (generate with: openssl rand -hex 32)
INTERNAL_SERVICE_SECRET=change-me-shared-secret-in-production

# ─────────────────────────────────────────────────────────────────────────────
# Matrix Synapse — Chat Transport (requires MATRIX_ENABLED=true and the
# `chat` Compose profile)
# ─────────────────────────────────────────────────────────────────────────────
MATRIX_SERVER_URL=http://localhost:8020
MATRIX_PUBLIC_SERVER_URL=http://localhost:8020
MATRIX_SERVER_NAME=comms.local
MATRIX_BOT_USERNAME=comms-bot
MATRIX_BOT_PASSWORD=change-me-bot-password
MATRIX_REGISTRATION_SHARED_SECRET=change-me-registration-secret

# ─────────────────────────────────────────────────────────────────────────────
# Janus WebRTC Gateway — Audio/Video Transport (requires JANUS_ENABLED=true
# and the `media` Compose profile)
# ─────────────────────────────────────────────────────────────────────────────
JANUS_HTTP_URL=http://localhost:8088/janus
JANUS_WS_URL=ws://localhost:8188
JANUS_PUBLIC_WS_URL=ws://localhost:8188
JANUS_NAT_1_1=

# ICE Servers (comma-separated STUN/TURN URLs)
JANUS_ICE_SERVERS=stun:stun.l.google.com:19302
JANUS_TURN_USERNAME=
JANUS_TURN_CREDENTIAL=

# coturn — TURN/STUN Relay (standalone docker-compose only, `media` profile)
TURN_USERNAME=comms
TURN_PASSWORD=change-me-turn-password
TURN_REALM=comms.local
TURN_EXTERNAL_IP=
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200

# ─────────────────────────────────────────────────────────────────────────────
# LiveKit — Alternative WebRTC backend (requires MEDIA_PROVIDER=livekit and
# the `livekit` Compose profile). Adapter TBD — see docs/PROVIDERS.md.
#
# Generate keys locally with:
#   docker run --rm livekit/livekit-server generate-keys
# ─────────────────────────────────────────────────────────────────────────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change-me-livekit-secret

# ─────────────────────────────────────────────────────────────────────────────
# SIP Softphone Access (requires SIP_ENABLED=true and the `sip` Compose
# profile — also requires `media` since SIP bridges into Janus AudioBridge)
#
# This feature is FREE and SELF-HOSTED: users register free SIP softphones
# (Linphone, Zoiper, MicroSIP, Jitsi, Bria) with the Kamailio sidecar and
# dial `sip:room-<contextId>@<SIP_DOMAIN>` to join the room's AudioBridge.
#
# IMPORTANT: this is NOT PSTN. There are no real phone numbers, no carrier,
# and no per-minute charges. See docs/sip/ for details.
# ─────────────────────────────────────────────────────────────────────────────

# SIP domain advertised to softphones and used in room URIs
SIP_DOMAIN=comms.local

# Hostname of the Kamailio registrar (Docker network name or DNS)
SIP_REGISTRAR_HOST=comms-kamailio
SIP_REGISTRAR_PORT=5060

# Transport: udp | tcp | tls
SIP_TRANSPORT=udp

# Optional — public-facing FQDN for softphones outside the Docker network
SIP_PUBLIC_HOST=

# Credentials for Janus's own SIP user (the bridge identity that Kamailio
# routes inbound calls to). Generated on first boot if left blank, then
# persisted to the Kamailio subscriber table.
SIP_BRIDGE_USERNAME=janus
SIP_BRIDGE_PASSWORD=

# Resource guardrails (no money involved, but capacity still matters)
SIP_MAX_CALL_SECONDS=7200
SIP_MAX_CONCURRENT_CALLS_PER_APP=50
SIP_MAX_REGISTRATIONS_PER_USER=3

# Kamailio's Postgres credentials (same cluster as comms-service)
# Default to the existing postgres superuser; change for production
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=vps-comms-db

# Host port mappings for Kamailio (override for conflicts)
SIP_HOST_PORT_UDP=5060
SIP_HOST_PORT_TCP=5060
