# ─────────────────────────────────────────────────────────────────────────────
# Communications Service — Configuration Template
# Copy to .env and adjust values for your environment.
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
COMMS_SERVICE_PORT=3014

# Database
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/vps-comms-db?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin123@localhost:5672
RMQ_EXCHANGE=comms_events_fanout
RMQ_QUEUE=comms_events

# Internal Service-to-Service Auth (generate with: openssl rand -hex 32)
INTERNAL_SERVICE_SECRET=change-me-shared-secret-in-production

# Matrix Synapse — Chat Transport
MATRIX_SERVER_URL=http://localhost:8020
MATRIX_PUBLIC_SERVER_URL=http://localhost:8020
MATRIX_SERVER_NAME=comms.local
MATRIX_BOT_USERNAME=comms-bot
MATRIX_BOT_PASSWORD=change-me-bot-password
MATRIX_REGISTRATION_SHARED_SECRET=change-me-registration-secret

# Janus WebRTC Gateway — Audio/Video Transport
JANUS_HTTP_URL=http://localhost:8088/janus
JANUS_WS_URL=ws://localhost:8188
JANUS_PUBLIC_WS_URL=ws://localhost:8188
JANUS_NAT_1_1=

# ICE Servers (comma-separated STUN/TURN URLs)
JANUS_ICE_SERVERS=stun:stun.l.google.com:19302
JANUS_TURN_USERNAME=
JANUS_TURN_CREDENTIAL=

# coturn — TURN/STUN Relay (standalone docker-compose only)
TURN_USERNAME=comms
TURN_PASSWORD=change-me-turn-password
TURN_REALM=comms.local
TURN_EXTERNAL_IP=
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200
